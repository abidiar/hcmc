---
interface Props {
  eyebrow: string;
  title: string;
  text: string;
  formAction: string;
  note?: string;
}

const { eyebrow, title, text, formAction, note } = Astro.props;
---

<section class="bg-civic-ink py-14 text-white">
  <div class="container-page grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
    <div>
      <p class="text-sm font-bold uppercase tracking-[0.16em] text-civic-gold">{eyebrow}</p>
      <h2 class="mt-3 text-3xl font-bold leading-tight sm:text-4xl">{title}</h2>
      <p class="mt-4 max-w-2xl leading-7 text-white/75">{text}</p>
    </div>
    <form
      action={formAction}
      method="post"
      target="_blank"
      class="rounded border border-white/10 bg-white p-4 text-civic-ink shadow-soft sm:p-5"
    >
      <div class="grid gap-3 sm:grid-cols-[1fr_auto]">
        <label class="sr-only" for="newsletter-email">Email address</label>
        <input
          id="newsletter-email"
          class="min-h-12 rounded border border-civic-ink/15 bg-civic-paper px-4 text-base text-civic-ink placeholder:text-civic-ink/45 focus:border-civic-teal"
          type="email"
          name="EMAIL"
          autocomplete="email"
          placeholder="Email address"
          required
        />
        <button
          class="min-h-12 rounded bg-civic-gold px-5 font-bold text-civic-ink hover:bg-[#B4812B]"
          type="submit"
        >
          Sign Up
        </button>
      </div>
      {note && <p class="mt-3 text-sm leading-6 text-civic-ink/65">{note}</p>}
    </form>
  </div>
</section>
