---
import { withBase } from '@/lib/paths';

const year = new Date().getFullYear();
---

<footer class="border-t border-civic-ink/10 bg-civic-ink text-white">
  <div class="container-page grid gap-10 py-12 md:grid-cols-[1.2fr_0.8fr_0.8fr]">
    <div>
      <p class="text-xl font-bold">Howard County Muslim Council</p>
      <p class="mt-4 max-w-xl text-white/75">
        A civic-minded nonprofit presence supporting service, education, partnership, and belonging across Howard County.
      </p>
    </div>
    <div>
      <p class="font-bold">Visit</p>
      <ul class="mt-4 space-y-2 text-white/75">
        <li><a class="hover:text-white" href={withBase('/about/')}>About</a></li>
        <li><a class="hover:text-white" href={withBase('/programs/')}>Programs</a></li>
        <li><a class="hover:text-white" href={withBase('/events/')}>Events</a></li>
        <li><a class="hover:text-white" href={withBase('/contact/')}>Contact</a></li>
      </ul>
    </div>
    <div>
      <p class="font-bold">Connect</p>
      <p class="mt-4 text-white/75">Howard County, Maryland</p>
      <p class="mt-2 text-white/75">info@example.org</p>
    </div>
  </div>
  <div class="border-t border-white/10">
    <div class="container-page flex flex-col gap-3 py-5 text-sm text-white/65 sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; {year} Howard County Muslim Council. All rights reserved.</p>
      <p>Static public website. No backend, login, database, or payment processing included.</p>
    </div>
  </div>
</footer>
