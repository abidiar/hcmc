---
import { withBase } from '@/lib/paths';

interface Card {
  title: string;
  text: string;
  href?: string;
  meta?: string;
  image?: string;
  imageAlt?: string;
}

interface Props {
  cards?: Card[];
}

const { cards = [] } = Astro.props;
---

<div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
  {
    cards.map((card) => (
      <article class="rounded border border-civic-ink/10 bg-white shadow-sm">
        {card.image && <img class="h-48 w-full rounded-t object-cover" src={withBase(card.image)} alt={card.imageAlt ?? ''} loading="lazy" />}
        <div class="p-6">
          {card.meta && <p class="text-sm font-semibold text-civic-teal">{card.meta}</p>}
          <h3 class="mt-2 text-xl font-bold text-civic-ink">{card.title}</h3>
          <p class="mt-3 leading-7 text-civic-ink/70">{card.text}</p>
          {card.href && (
            <a class="mt-5 inline-flex font-bold text-civic-pine hover:text-civic-teal" href={withBase(card.href)}>
              Learn more
            </a>
          )}
        </div>
      </article>
    ))
  }
</div>
