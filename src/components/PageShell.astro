---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import CardGrid from '@/components/CardGrid.astro';
import NewsletterSignup from '@/components/NewsletterSignup.astro';
import { withBase } from '@/lib/paths';

interface Props {
  page: any;
  cards?: Array<{
    title: string;
    text: string;
    href?: string;
    meta?: string;
    image?: string;
    imageAlt?: string;
  }>;
  cardsEyebrow?: string;
  cardsTitle?: string;
}

const { page, cards = [], cardsEyebrow, cardsTitle } = Astro.props;
const { Content } = await page.render();
const data = page.data;
---

<BaseLayout title={data.title} description={data.description}>
  <Hero
    eyebrow={data.eyebrow}
    title={data.title}
    description={data.description}
    image={data.heroImage}
    imageAlt={data.heroAlt}
    primaryAction={data.primaryAction}
    secondaryAction={data.secondaryAction}
  />

  {data.highlights && (
    <section class="bg-white py-8">
      <div class="container-page grid gap-4 md:grid-cols-3">
        {
          data.highlights.map((item) => (
            <div class="rounded border border-civic-ink/10 bg-civic-paper p-5">
              <p class="text-sm font-bold uppercase tracking-[0.14em] text-civic-teal">{item.label}</p>
              <p class="mt-2 text-civic-ink/75">{item.text}</p>
            </div>
          ))
        }
      </div>
    </section>
  )}

  <section class="py-14 lg:py-16">
    <div class="container-page grid gap-10 lg:grid-cols-[0.72fr_0.28fr]">
      <article class="prose-page">
        <Content />
      </article>
      <aside class="space-y-5">
        <div class="rounded border border-civic-ink/10 bg-civic-sky p-6">
          <p class="text-sm font-bold uppercase tracking-[0.14em] text-civic-teal">Public Information</p>
          <p class="mt-3 text-civic-ink/75">
            This site is designed as a static public resource. Replace placeholder dates, contacts, and images before launch.
          </p>
        </div>
        <div class="rounded border border-civic-ink/10 bg-white p-6 shadow-sm">
          <p class="text-lg font-bold">Quick Contact</p>
          <p class="mt-3 text-civic-ink/70">For questions, partnerships, or media inquiries, use the contact page.</p>
          <a class="mt-5 inline-flex rounded bg-civic-pine px-4 py-2.5 font-bold text-white hover:bg-civic-teal" href={withBase('/contact/')}>Contact Us</a>
        </div>
      </aside>
    </div>
  </section>

  {data.featureCards && (
    <section class="bg-civic-mist py-14">
      <div class="container-page">
        <p class="eyebrow">Explore</p>
        <h2 class="mt-3 text-3xl font-bold text-civic-ink">Ways We Serve</h2>
        <div class="mt-8">
          <CardGrid cards={data.featureCards} />
        </div>
      </div>
    </section>
  )}

  {cards.length > 0 && (
    <section class="bg-white py-14">
      <div class="container-page">
        {cardsEyebrow && <p class="eyebrow">{cardsEyebrow}</p>}
        {cardsTitle && <h2 class="mt-3 text-3xl font-bold text-civic-ink">{cardsTitle}</h2>}
        <div class="mt-8">
          <CardGrid cards={cards} />
        </div>
      </div>
    </section>
  )}

  {data.newsletter && (
    <NewsletterSignup
      eyebrow={data.newsletter.eyebrow}
      title={data.newsletter.title}
      text={data.newsletter.text}
      formAction={data.newsletter.formAction}
      honeypotName={data.newsletter.honeypotName}
      note={data.newsletter.note}
    />
  )}
</BaseLayout>
